# Copy this file to .env on the EC2 server and replace placeholder values.

NODE_ENV=production
PORT=3000
TRUST_PROXY=true

# TLS should terminate at Nginx or another reverse proxy in front of Node.
# Replace this value if the EC2 public IP or domain changes.
PUBLIC_IP=api.binbao.id.vn

# Comma-separated list of allowed frontend origins. Avoid "*" in production.
ALLOWED_ORIGINS=https://app.example.com,https://www.app.example.com

# Keep this default if you run MongoDB from docker-compose.prod.yml.
MONGODB_URI=mongodb://mongodb:27017/plant_disease_db
MONGO_DB_NAME=plant_disease_db

# Generate a long random secret for production.
JWT_SECRET=replace-with-a-long-random-secret

# Required for OTP email flow.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Required for the server-side chatbot proxy.
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Upload and inference safety rails.
MAX_IMAGE_WIDTH=6000
MAX_IMAGE_HEIGHT=6000
MAX_UPLOAD_PIXELS=25000000
MAX_CONCURRENT_INFERENCE=2
MAX_PENDING_INFERENCE=8
